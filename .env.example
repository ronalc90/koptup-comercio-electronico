# Supabase - Obtener de https://app.supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJtu-anon-key-aqui

# OpenAI - Obtener de https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-api-key-aqui

# Auth
# AUTH_SECRET es OBLIGATORIA en producción: firma los JWT de sesión (HS256).
# Debe tener al menos 32 caracteres aleatorios (256 bits). En producción la app
# NO arranca si está vacía o es más corta. Generar con: openssl rand -hex 32
AUTH_SECRET=cambia-esto-por-un-string-seguro-aleatorio-de-32-mas
AUTH_USERNAME=Paola
AUTH_PASSWORD_HASH=$2a$10$placeholder

# Multi-tenant hardening (OPCIONAL). Si se define, la app firma un JWT por
# usuario con el claim tenant_id y el navegador lo usa como bearer, de modo que
# las políticas RLS de la migración 003 fuerzan el aislamiento en la base.
# Obtener de Supabase → Settings → API → JWT Secret. Dejar vacío para mantener
# el comportamiento actual (anon key + guard de JS).
SUPABASE_JWT_SECRET=
