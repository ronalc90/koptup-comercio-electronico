# Supabase - Obtener de https://app.supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJtu-anon-key-aqui

# SUPABASE_SERVICE_ROLE_KEY (service_role): la usan las rutas del servidor
# (getServiceClient) para operar de forma controlada. OBLIGATORIA en producción:
# si falta, las rutas del servidor degradan a la anon key y muchas operaciones
# (admin, superadmin, login, cron…) fallarían. Settings > API > service_role
# secret. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJtu-service-role-key-aqui

# SUPABASE_ACCESS_TOKEN (OPCIONAL, solo tooling de desarrollo): token sbp_ del
# Management API para aplicar migraciones con `npm run db:exec`. No se usa en
# runtime. Generar en https://app.supabase.com/account/tokens
SUPABASE_ACCESS_TOKEN=

# OpenAI - Obtener de https://platform.openai.com/api-keys (también se puede
# configurar por-negocio desde Configuración, que tiene prioridad sobre esta).
OPENAI_API_KEY=sk-tu-api-key-aqui

# Auth
# AUTH_SECRET es OBLIGATORIA en producción: firma los JWT de sesión (HS256).
# Debe tener al menos 32 caracteres aleatorios (256 bits). En producción la app
# NO arranca si está vacía o es más corta. Generar con: openssl rand -hex 32
AUTH_SECRET=cambia-esto-por-un-string-seguro-aleatorio-de-32-mas
AUTH_USERNAME=Paola
AUTH_PASSWORD_HASH=$2a$10$placeholder

# Multi-tenant hardening (OPCIONAL). Si se define, la app firma un JWT por
# usuario con el claim tenant_id y el navegador lo usa como bearer, de modo que
# las políticas RLS de la migración 003 fuerzan el aislamiento en la base.
# Obtener de Supabase → Settings → API → JWT Secret. Dejar vacío para mantener
# el comportamiento actual (anon key + guard de JS).
SUPABASE_JWT_SECRET=

# Cron de agentes IA (OPCIONAL). Si se define, Vercel Cron puede correr
# /api/cron/run-agents (ver vercel.json) enviándolo como bearer. Sin definirlo,
# el cron automático no autoriza, pero el superadmin igual lo dispara a mano
# desde la pantalla "Plataforma".
CRON_SECRET=

# ── Stripe (pagos de licencias, OPCIONAL) ─────────────────────────────────────
# Si no se definen, los pagos quedan desactivados (la app funciona igual; el
# botón "Pagar" no aparece). Empieza SIEMPRE con llaves de PRUEBA (sk_test_/pk_test_).
# Guía: docs/STRIPE_SETUP.md
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (recurrentes mensuales en COP) creados en Stripe para cada plan:
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
